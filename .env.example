# Surge / SSH
SURGE_HOST=127.0.0.1
SURGE_SSH_USER=
SURGE_SSH_KEY_PATH=
SURGE_SSH_PASS_FILE=
SURGE_SSH_PASS=
SURGE_SSH_PORT=22
SURGE_SSH_DISABLE_STRICT_HOST_KEY_CHECKING=1
SURGE_API_KEY=
SURGE_API_LOCAL_PORT=16679
SURGE_API_REMOTE_PORT=16678
SURGE_SQLITE_PATH=/Users/your_username/Library/Application Support/com.nssurge.surge-mac/TrafficStatData/Session

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=
MYSQL_DB=surge_traffic

# DB behavior
DB_CONNECT_TIMEOUT=10
DB_CONNECT_RETRIES=3
DB_CONNECT_RETRY_DELAY=5
DB_POOL_MAX_CONNECTIONS=10
DB_POOL_MIN_CACHED=1
DB_POOL_MAX_CACHED=5

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m2.7
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Collector behavior
DEVICE_SYNC_INTERVAL=300
SQLITE_SYNC_INTERVAL=3600
BLOCKLIST_UPDATE_INTERVAL=86400
REQUEST_PARTITION_MONTHS_AHEAD=6
